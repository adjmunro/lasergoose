#!/usr/bin/env zsh
# lasergoose — reusable GUI feedback loop
# Captures a running app's window, optionally building first.
# Repo: ~/Developer/lasergoose/
set -euo pipefail

SCRIPT_DIR="${0:A:h}"

# ── Defaults (overridable via env vars) ──────────────────────────────────────
APP="${LASERGOOSE_APP:-ThunderSloth}"
PLATFORM="${LASERGOOSE_PLATFORM:-macos}"
BUILD="${LASERGOOSE_BUILD:-none}"
SCHEME="${LASERGOOSE_SCHEME:-}"
PROJECT="${LASERGOOSE_PROJECT:-}"
OUT="${LASERGOOSE_OUT:-/tmp/lasergoose.png}"
HOT=false
SCRIPT=""
PREVIEW=false

# ── Argument parsing ─────────────────────────────────────────────────────────
while [[ $# -gt 0 ]]; do
  case "$1" in
    --app)      APP="$2";      shift 2 ;;
    --platform) PLATFORM="$2"; shift 2 ;;
    --build)    BUILD="$2";    shift 2 ;;
    --scheme)   SCHEME="$2";   shift 2 ;;
    --project)  PROJECT="$2";  shift 2 ;;
    --out)      OUT="$2";      shift 2 ;;
    --hot)      HOT=true;      shift   ;;
    --preview)  PREVIEW=true;  shift   ;;
    --script)   SCRIPT="$2";   shift 2 ;;
    -h|--help)
      cat <<'HELP'
Usage: lasergoose [OPTIONS]

Options:
  --app      <name>                App/process display name  (default: $LASERGOOSE_APP or "ThunderSloth")
  --platform <macos|ios-sim|android>  Capture method         (default: $LASERGOOSE_PLATFORM or "macos")
  --build    <xcode|spm|gradle|none>  Build before capture   (default: none)
  --scheme   <name>                Xcode scheme (for xcode build)
  --project  <path>                .xcodeproj or .xcworkspace path
  --hot                            Use hot-reload instead of full build
  --out      <path>                Output PNG path            (default: /tmp/lasergoose.png)
  --script   <applescript>         osascript to run before capture (e.g. click, keystroke)
  --preview                        Display screenshot inline in terminal after capture

Environment variables:
  LASERGOOSE_APP, LASERGOOSE_PLATFORM, LASERGOOSE_BUILD, LASERGOOSE_SCHEME, LASERGOOSE_PROJECT, LASERGOOSE_OUT

Examples:
  lasergoose --app ThunderSloth --platform macos
  lasergoose --app ThunderSloth --platform macos --build xcode --scheme ThunderSlothApp \
       --project ~/Developer/ThunderSloth/ThunderSloth/ThunderSloth.xcodeproj
  lasergoose --app MyAndroidApp --platform android --build gradle
  lasergoose --platform ios-sim
HELP
      exit 0
      ;;
    *) echo "lasergoose: unknown option: $1" >&2; exit 1 ;;
  esac
done

# ── Inline preview (iTerm2 protocol, supported by Ghostty) ──────────────────
lasergoose_preview() {
  local file="$1"
  local data
  data=$(base64 < "$file")
  printf '\033]1337;File=inline=1;width=auto;height=auto:%s\a\n' "$data"
}

# ── Step 1: Build (optional) ─────────────────────────────────────────────────
if [[ "$HOT" == true ]]; then
  echo "lasergoose: hot-reload requested"
  case "$BUILD" in
    xcode|none)
      echo "lasergoose: sending hot-reload keystroke to Xcode…"
      osascript \
        -e 'tell application "Xcode" to activate' \
        -e 'tell application "System Events" to keystroke "r" using {command down, control down}'
      sleep 1
      ;;
    gradle)
      echo "lasergoose: Android hot-reload stub — app must handle com.your.app.RELOAD broadcast"
      "$HOME/Library/Android/sdk/platform-tools/adb" shell \
        am broadcast -a com.your.app.RELOAD || true
      ;;
  esac
elif [[ "$BUILD" != "none" ]]; then
  echo "lasergoose: building via $BUILD…"
  export LASERGOOSE_SCHEME="$SCHEME"
  export LASERGOOSE_PROJECT="$PROJECT"
  case "$BUILD" in
    xcode)  bash "$SCRIPT_DIR/builds/xcode.sh"  ;;
    spm)    bash "$SCRIPT_DIR/builds/spm.sh"    ;;
    gradle) bash "$SCRIPT_DIR/builds/gradle.sh" ;;
    *) echo "lasergoose: unknown build type: $BUILD" >&2; exit 1 ;;
  esac
fi

# ── Step 1.5: Run osascript (optional) ───────────────────────────────────────
if [[ -n "$SCRIPT" ]]; then
  echo "lasergoose: running script…"
  osascript -e "$SCRIPT"
  sleep 0.4
fi

# ── Step 2: Capture ──────────────────────────────────────────────────────────
echo "lasergoose: capturing $APP on $PLATFORM → $OUT"
export APP_NAME="$APP"
export OUT="$OUT"
case "$PLATFORM" in
  macos)     bash "$SCRIPT_DIR/platforms/macos.sh"   ;;
  ios-sim)   bash "$SCRIPT_DIR/platforms/ios-sim.sh" ;;
  android)   bash "$SCRIPT_DIR/platforms/android.sh" ;;
  *) echo "lasergoose: unknown platform: $PLATFORM" >&2; exit 1 ;;
esac

echo "lasergoose: saved → $OUT"

if [[ "$PREVIEW" == true ]]; then
  echo "lasergoose: preview ↓"
  lasergoose_preview "$OUT"
fi
